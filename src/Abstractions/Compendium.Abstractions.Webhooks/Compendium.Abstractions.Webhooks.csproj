<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Compendium.Abstractions.Webhooks</AssemblyName>
    <RootNamespace>Compendium.Abstractions.Webhooks</RootNamespace>
    <PackageId>Compendium.Abstractions.Webhooks</PackageId>
